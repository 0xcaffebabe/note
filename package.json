    "js-yaml": "4.1.1",
    "jsmind": "0.9.1",
    "katex": "0.16.33",
    "less": "4.5.1",
    "marked": "18.0.4",
    "mermaid": "11.15.0",
    "prismjs": "1.30.0",
    "svg-pan-zoom": "3.6.2",
    "tiny-pinyin": "1.3.2",
    "vue": "3.5.29",
    "vue-router": "5.0.3",
    "vuex": "4.1.0"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/js-yaml": "4.0.9",
