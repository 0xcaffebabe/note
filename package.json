    "js-yaml": "4.1.1",
    "jsmind": "0.9.1",
    "katex": "0.18.1",
    "less": "4.8.0",
    "marked": "18.0.7",
    "mermaid": "11.16.0",
    "prismjs": "1.30.0",
    "svg-pan-zoom": "3.6.2",
    "tiny-pinyin": "1.3.2",
    "vue": "3.5.40",
    "vue-router": "5.2.0",
    "vuex": "4.1.0"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/js-yaml": "4.0.9",
